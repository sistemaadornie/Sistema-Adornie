PORT=3001
# Em produção atrás de nginx/Heroku/Railway: defina 1
# TRUST_PROXY=1

DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=
DB_NAME=sistema_liuu
DB_PORT=5432

# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRY=1d
TOKEN_HMAC_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Google Drive (Service Account) ────────────────────────────
# JSON completo da chave da Service Account (Google Cloud Console)
# Nunca commite o JSON real — use variável de ambiente ou secret manager
GOOGLE_SA_KEY_JSON=
# ID da pasta raiz no Drive (compartilhada com o email da Service Account)
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Origens permitidas pelo CORS (separadas por vírgula)
# ALLOWED_ORIGINS=http://localhost:5173,https://seu-frontend.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Sistema <noreply@seudominio.com>

FRONTEND_URL=http://localhost:5173

# ── Push notifications (Web Push) ─────────────────────────────
# Gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:suporte@adornie.com
